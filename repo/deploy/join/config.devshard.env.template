# Devshard gateway environment template
#
# Use with:
#   docker compose -f docker-compose.devshard-gateway.yml up -d devshard-gateway
#
# Compose-level variables like DEVSHARD_INSTANCE_NAME and DEVSHARD_ENV_FILE are
# resolved by Docker Compose itself, so set those in your shell or compose .env
# file if you need them to affect container_name or env_file selection.

# Shared settings
# Gateway runtime topology is bootstrapped from this file only on first start.
# Once /root/.devshardctl/gateway.db exists, devshard membership and gateway settings
# are loaded from that state DB instead of these env values.
export DEVSHARD_CHAIN_REST=http://node:1317
export DEVSHARD_PUBLIC_API=http://api:9000
export DEVSHARD_PORT=8080
export DEVSHARD_STORAGE_DIR=/root/.devshardctl
export DEVSHARD_STORAGE_HOST_DIR=.devshardctl
export DEVSHARD_API_KEYS=sk-your-key-1,sk-your-key-2
export DEVSHARD_ADMIN_API_KEY=sk-admin-your-key
export GATEWAY_MAX_CONCURRENT_REQUESTS=0
export GATEWAY_MAX_INPUT_TOKENS_IN_FLIGHT=0
export GATEWAY_DEFAULT_MAX_TOKENS=10000

# Gateway disabled state. Leave disabled by default. When enabled, every
# non-admin request returns a 308 redirect-shaped JSON response.
# export DEVSHARD_GATEWAY_DISABLED=true
# export DEVSHARD_GATEWAY_DISABLED_MESSAGE="please use https://.../v1/ base url"
# export DEVSHARD_GATEWAY_DISABLED_NEW_URL="https://.../v1/chat/completions"

# PoC behavior and capacity-aware limits.
#
# DEVSHARD_POC_REQUEST_MODE
#   off     -- reject inference requests while any registered devshard is in PoC
#              (old behavior: all-or-nothing shutdown during PoC phases).
#   relaxed -- keep serving during PoC using silent ghost probes for locked
#              or throttled hosts so the nonce stream and chain state keep
#              advancing without exhausting unavailable hosts. Recommended.
#
# DEVSHARD_CAPACITY_AWARE_LIMITS
#   off  -- legacy rate-limit behavior: GatewayLimiter bypasses caps during
#           PoC, picker uses static weights.
#   on   -- CapacityState-driven behavior:
#             * GatewayLimiter scales caps by live W_tot/W_ref so PoC-reduced
#               capacity shrinks admission proportionally instead of being
#               bypassed outright.
#             * Runtime picker balances by load = activeRequests / W(e)
#               where W(e) reflects per-host availability, share across
#               escrows, poc_ok(h), and reactive throttle.
#             * ParticipantRequestLimiter stays active during PoC so a 503ing
#               host is treated as unavailable (binary, with hysteresis) for
#               both picker and throttle purposes.
#           Recommended with DEVSHARD_POC_REQUEST_MODE=relaxed.
export DEVSHARD_POC_REQUEST_MODE=relaxed
export DEVSHARD_CAPACITY_AWARE_LIMITS=on

# Automatic escrow rotation. Bootstrapped from env only on first start; after
# gateway.db exists, update these via POST /v1/admin/settings.
#
# At pre_poc_blocks before the next epoch switch at set_new_validators, the
# gateway creates temp bridge escrows, then locally deactivates/finalizes/settles
# regular escrows. It also replaces low-balance/high-nonce escrows. After the
# next epoch leaves PoC, it creates target_count regular escrows and settles the
# temp ones. Keep settlement disabled to create/deactivate automatically but
# skip automatic finalization and on-chain settlement.
# export DEVSHARD_ESCROW_ROTATION_ENABLED=true
# export DEVSHARD_ESCROW_ROTATION_SETTLEMENT_ENABLED=false
# export DEVSHARD_ESCROW_ROTATION_PRE_POC_BLOCKS=300
# export DEVSHARD_ESCROW_ROTATION_MODELS_JSON='[
#   {"model_id":"Qwen/Qwen3-235B-A22B-Instruct-2507-FP8","temp_count":8,"target_count":16,"amount":5000000000,"private_key_env":"DEVSHARD_PRIVATE_KEY"}
# ]'

# ---------------------------------------------------------------------------
# Single-devshard mode example
# ---------------------------------------------------------------------------
# Set this in your shell or compose .env if you want a stable container name.
# Direct proxy mode uses /devshard-gateway-direct/<escrow-id>/... and expects
# this per-escrow name to be resolvable on the proxy network.
# export DEVSHARD_INSTANCE_NAME=devshard-gateway-12
#
# These values are read inside the container from this env file.
# Keep the storage path aligned with the escrow ID so single and multi mode
# reuse the same persisted state.
#
# export DEVSHARD_PRIVATE_KEY=<FILLIN>
# export DEVSHARD_ESCROW_ID=12
# export DEVSHARD_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507-FP8
# export DEVSHARD_STORAGE_PATH=/root/.devshardctl/escrow-12/state.db

# ---------------------------------------------------------------------------
# Multi-devshard gateway mode example
# ---------------------------------------------------------------------------
# Set this in your shell or compose .env if you want a stable container name.
# Gateway proxy mode uses /devshard-gateway/... and expects this name to be
# resolvable on the proxy network.
# export DEVSHARD_INSTANCE_NAME=devshard-gateway-multi
#
# export DEVSHARDS_JSON='[
#   {"id":"12","private_key_env":"DEVSHARD_12_PRIVATE_KEY","model":"Qwen/Qwen3-235B-A22B-Instruct-2507-FP8"},
#   {"id":"13","private_key_env":"DEVSHARD_13_PRIVATE_KEY","model":"Qwen/Qwen3-235B-A22B-Instruct-2507-FP8"}
# ]'
# export DEVSHARD_12_PRIVATE_KEY=<FILLIN>
# export DEVSHARD_13_PRIVATE_KEY=<FILLIN>
